# 이 파일을 복사해서 .env 파일로 만든 뒤 실제 값을 채워넣으세요.
# cp .env.example .env

# PostgreSQL
DB_USERNAME=myassistant
DB_PASSWORD=your_db_password_here
DB_R2DBC_URL=r2dbc:postgresql://localhost:5432/myassistant
DB_JDBC_URL=jdbc:postgresql://localhost:5432/myassistant

# OpenAI
OPENAI_API_KEY=sk-...

# JWT (base64 인코딩된 256비트 이상 키)
# 생성 명령: openssl rand -base64 32
JWT_SECRET=your_base64_encoded_secret_here
